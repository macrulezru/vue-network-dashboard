{
  "name": "vue-network-dashboard",
  "version": "0.1.0",
  "description": "Universal network logger for Vue 3 applications - intercepts HTTP and WebSocket traffic",
  "type": "module",
  "main": "./dist/vue-network-dashboard.umd.js",
  "module": "./dist/vue-network-dashboard.esm.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-network-dashboard.esm.js",
      "require": "./dist/vue-network-dashboard.umd.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite --open",
    "build": "vite build && tsc --emitDeclarationOnly",
    "preview": "vite preview --open",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts,.vue",
    "lint:fix": "eslint src --ext .ts,.vue --fix",
    "lint:css": "stylelint \"src/**/*.scss\"",
    "lint:css:fix": "stylelint \"src/**/*.scss\" --fix",
    "format": "prettier --write \"src/**/*.{ts,vue,scss}\"",
    "prepublishOnly": "npm run build",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "vue",
    "vue3",
    "network",
    "logger",
    "fetch",
    "xhr",
    "websocket",
    "debugging",
    "monitoring"
  ],
  "author": {
    "name": "Danil Lisin",
    "email": "macrulezru@gmail.com",
    "url": "https://macrulez.ru"
  },
  "homepage": "https://macrulez.ru",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/macrulezru/vue-network-dashboard.git"
  },
  "bugs": {
    "url": "https://github.com/macrulezru/vue-network-dashboard/issues"
  },
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vue/test-utils": "^2.4.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.54.0",
    "eslint-plugin-vue": "^9.19.0",
    "jsdom": "^23.0.0",
    "postcss": "^8.5.8",
    "prettier": "^3.1.0",
    "sass": "^1.98.0",
    "stylelint": "^17.6.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-scss": "^7.0.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-dts": "^3.6.0",
    "vitest": "^1.0.0",
    "vue": "^3.5.31"
  }
}
